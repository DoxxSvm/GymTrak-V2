{
  "info": {
    "name": "GymTrak Mobile Auth APIs",
    "_postman_id": "0f8513b6-2fe6-4726-9d4b-855a11f8ce2d",
    "description": "Collection for splash config and owner/trainer auth flows.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api/v1"
    },
    {
      "key": "accessToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "App Config",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/app/config"
      }
    },
    {
      "name": "Send OTP",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phone\": \"9876543210\",\n  \"country_code\": \"+91\"\n}"
        },
        "url": "{{baseUrl}}/auth/send-otp"
      }
    },
    {
      "name": "Resend OTP",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phone\": \"9876543210\",\n  \"country_code\": \"+91\"\n}"
        },
        "url": "{{baseUrl}}/auth/resend-otp"
      }
    },
    {
      "name": "Verify OTP",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phone\": \"9876543210\",\n  \"country_code\": \"+91\",\n  \"otp\": \"123456\"\n}"
        },
        "url": "{{baseUrl}}/auth/verify-otp"
      }
    },
    {
      "name": "Trainer/Owner Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"trainer1\",\n  \"password\": \"secret123\"\n}"
        },
        "url": "{{baseUrl}}/auth/login"
      }
    },
    {
      "name": "Logout",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refresh_token\": \"<refresh-token>\"\n}"
        },
        "url": "{{baseUrl}}/auth/logout"
      }
    }
  ]
}
