{
  "info": {
    "name": "Plan / Package Management APIs",
    "_postman_id": "0d39c8fb-e978-4cd8-a8de-e89f2f5c0094",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1" },
    { "key": "token", "value": "" },
    { "key": "gymId", "value": "" },
    { "key": "planId", "value": "" },
    { "key": "memberId", "value": "" }
  ],
  "item": [
    {
      "name": "Create Plan (Compat)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"gymId\": \"{{gymId}}\",\n  \"plan_type\": \"batch\",\n  \"plan_name\": \"Gold Membership\",\n  \"duration_days\": 30,\n  \"price\": 5000,\n  \"trainer_id\": \"trainer-gym-user-id\",\n  \"batch_details\": {\n    \"working_days\": [\"mon\", \"tue\", \"wed\"],\n    \"start_time\": \"08:00\",\n    \"end_time\": \"09:00\",\n    \"gender\": \"unisex\"\n  }\n}"
        },
        "url": "{{baseUrl}}/plans/compat"
      }
    },
    {
      "name": "Validate Plan",
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"plan_type\": \"pt\",\n  \"plan_name\": \"PT Basic\",\n  \"duration_days\": 30,\n  \"price\": 5000\n}" },
        "url": "{{baseUrl}}/plans/validate"
      }
    },
    {
      "name": "List Plans",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/plans?gymId={{gymId}}"
      }
    },
    {
      "name": "Get Plan Details",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/plans/{{planId}}?gymId={{gymId}}"
      }
    },
    {
      "name": "Update Plan",
      "request": {
        "method": "PUT",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"plan_name\": \"Gold Membership Plus\",\n  \"price\": 5500\n}" },
        "url": "{{baseUrl}}/plans/{{planId}}?gymId={{gymId}}"
      }
    },
    {
      "name": "Delete Plan (Soft)",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/plans/{{planId}}?gymId={{gymId}}"
      }
    },
    {
      "name": "Assign Plan To Member",
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"member_id\": \"{{memberId}}\",\n  \"plan_id\": \"{{planId}}\",\n  \"start_date\": \"2026-03-24T00:00:00.000Z\",\n  \"discount\": 0\n}" },
        "url": "{{baseUrl}}/member-plans"
      }
    }
  ]
}
