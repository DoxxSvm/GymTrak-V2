{
  "info": {
    "name": "GymTrak API",
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "description": "GymTrak REST API (`/api/v1`). **Phone signup:** Auth > Phone login → Verify OTP → copy `tempToken` into collection variable `accessToken` → Owner signup > Select role (gym_owner) → Set gym or Create gym; response replaces tokens with full `access_token` / `refresh_token`. Use **Send owner OTP** only for existing gym-owner numbers.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "gymId", "value": "" }
  ],
  "item": [
    {
      "name": "Health & App",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        },
        {
          "name": "App config",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/app/config"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Phone login (send OTP)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"9876543210\",\n  \"country_code\": \"+91\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Password login (trainer/owner)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"demo_admin\",\n  \"password\": \"YourPassword8chars+\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Verify OTP (any phone)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const j = pm.response.json();",
                  "if (j.access_token) pm.collectionVariables.set('accessToken', j.access_token);",
                  "if (j.refresh_token) pm.collectionVariables.set('refreshToken', j.refresh_token);",
                  "if (j.tempToken) pm.collectionVariables.set('accessToken', j.tempToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"9876543210\",\n  \"country_code\": \"+91\",\n  \"otp\": \"123456\"\n}"
            },
            "url": "{{baseUrl}}/auth/verify-otp"
          }
        },
        {
          "name": "Send owner OTP (existing owner only)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"9876543210\",\n  \"country_code\": \"+91\"\n}"
            },
            "url": "{{baseUrl}}/auth/send-otp"
          }
        },
        {
          "name": "Resend owner OTP",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"9876543210\",\n  \"country_code\": \"+91\"\n}"
            },
            "url": "{{baseUrl}}/auth/resend-otp"
          }
        },
        {
          "name": "Staff login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const j = pm.response.json();",
                  "if (j.accessToken) pm.collectionVariables.set('accessToken', j.accessToken);",
                  "if (j.refreshToken) pm.collectionVariables.set('refreshToken', j.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"demo_admin\",\n  \"password\": \"YourPassword8chars+\"\n}"
            },
            "url": "{{baseUrl}}/auth/staff/login"
          }
        },
        {
          "name": "Refresh token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/refresh"
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Owner signup",
      "item": [
        {
          "name": "Select role (gym_owner)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const j = pm.response.json();",
                  "if (j.access_token) pm.collectionVariables.set('accessToken', j.access_token);",
                  "if (j.refresh_token) pm.collectionVariables.set('refreshToken', j.refresh_token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"gym_owner\"\n}"
            },
            "url": "{{baseUrl}}/user/select-role"
          }
        },
        {
          "name": "Set gym (owner app)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const j = pm.response.json();",
                  "if (j.access_token) pm.collectionVariables.set('accessToken', j.access_token);",
                  "if (j.refresh_token) pm.collectionVariables.set('refreshToken', j.refresh_token);",
                  "if (j.gym_id) pm.collectionVariables.set('gymId', j.gym_id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gym_name\": \"Iron Paradise\",\n  \"owner_name\": \"Amit\"\n}"
            },
            "url": "{{baseUrl}}/gym"
          }
        },
        {
          "name": "Create gym (REST)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const j = pm.response.json();",
                  "if (j.access_token) pm.collectionVariables.set('accessToken', j.access_token);",
                  "if (j.refresh_token) pm.collectionVariables.set('refreshToken', j.refresh_token);",
                  "if (j.id) pm.collectionVariables.set('gymId', j.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Iron Paradise\",\n  \"address\": \"Delhi\"\n}"
            },
            "url": "{{baseUrl}}/gyms"
          }
        }
      ]
    },
    {
      "name": "Gyms",
      "item": [
        {
          "name": "List gyms",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/gyms"
          }
        }
      ]
    },
    {
      "name": "Core",
      "item": [
        {
          "name": "Dashboard",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/dashboard?mobileView=owner&gymId={{gymId}}"
          }
        },
        {
          "name": "Members list",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/members?gymId={{gymId}}&page=1&limit=20"
          }
        },
        {
          "name": "Profile (unified)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/profile"
          }
        },
        {
          "name": "Profile (legacy)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/profile/legacy"
          }
        }
      ]
    }
  ]
}
