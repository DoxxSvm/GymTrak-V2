{
  "info": {
    "name": "Trainer Management + Notifications APIs",
    "_postman_id": "9ef9c0b2-a65a-4bff-87ea-03f43124fcb1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1" },
    { "key": "token", "value": "" },
    { "key": "gymId", "value": "" },
    { "key": "trainerId", "value": "" },
    { "key": "notificationId", "value": "" }
  ],
  "item": [
    {
      "name": "Get Notifications",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/notifications?gymId={{gymId}}"
      }
    },
    {
      "name": "Mark Notification Read",
      "request": {
        "method": "PUT",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/notifications/{{notificationId}}/read?gymId={{gymId}}"
      }
    },
    {
      "name": "Get Trainers",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/trainers?gymId={{gymId}}&q=marcus"
      }
    },
    {
      "name": "Add Trainer (Compat)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"gymId\": \"{{gymId}}\",\n  \"phone\": \"+919999999999\",\n  \"full_name\": \"Marcus\",\n  \"experience\": 3,\n  \"salary\": 5000,\n  \"salary_type\": \"monthly\",\n  \"expertise\": [\"weight training\", \"cardio\"],\n  \"shift\": {\"days\": [\"mon\", \"tue\"], \"start_time\": \"08:00\", \"end_time\": \"20:00\"},\n  \"permissions\": {\n    \"add_members\": true,\n    \"view_dashboard\": true,\n    \"view_payments\": false,\n    \"view_member_details\": true\n  }\n}"
        },
        "url": "{{baseUrl}}/trainers/compat"
      }
    },
    {
      "name": "Get Trainer Profile",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/trainers/{{trainerId}}?gymId={{gymId}}"
      }
    },
    {
      "name": "Update Trainer",
      "request": {
        "method": "PUT",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"fullName\": \"Marcus A\",\n  \"salaryCents\": 550000\n}" },
        "url": "{{baseUrl}}/trainers/{{trainerId}}?gymId={{gymId}}"
      }
    },
    {
      "name": "Trainer Members",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/trainers/{{trainerId}}/members?gymId={{gymId}}"
      }
    },
    {
      "name": "Change Trainer Password",
      "request": {
        "method": "PUT",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"password\": \"new_password_123\"\n}" },
        "url": "{{baseUrl}}/trainers/{{trainerId}}/password?gymId={{gymId}}"
      }
    },
    {
      "name": "Update Trainer Permissions",
      "request": {
        "method": "PUT",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"add_members\": true,\n  \"view_dashboard\": true,\n  \"view_payments\": false,\n  \"view_member_details\": true\n}" },
        "url": "{{baseUrl}}/trainers/{{trainerId}}/permissions?gymId={{gymId}}"
      }
    },
    {
      "name": "Delete Trainer (Soft)",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/trainers/{{trainerId}}?gymId={{gymId}}"
      }
    }
  ]
}
