{
  "info": {
    "name": "Shop + Product + Advanced Inquiry APIs",
    "_postman_id": "658cc950-ef34-482f-a5fd-8dfdfbb5f218",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1" },
    { "key": "token", "value": "" },
    { "key": "gymId", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "inquiryId", "value": "" }
  ],
  "item": [
    {
      "name": "Create Inquiry (Advanced)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"gymId\": \"{{gymId}}\",\n  \"first_name\": \"John\",\n  \"last_name\": \"Doe\",\n  \"phone\": \"9876543210\",\n  \"date\": \"2026-03-24\",\n  \"gender\": \"male\",\n  \"address\": \"Mumbai\",\n  \"source\": \"walk-in\",\n  \"interest\": \"weight loss\",\n  \"notes\": \"Interested in annual plan\"\n}"
        },
        "url": "{{baseUrl}}/inquiries"
      }
    },
    {
      "name": "List Inquiries",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/inquiries?gymId={{gymId}}&status=pending&q=john"
      }
    },
    {
      "name": "Update Inquiry Status",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"status\": \"lost\"\n}" },
        "url": "{{baseUrl}}/inquiries/{{inquiryId}}?gymId={{gymId}}"
      }
    },
    {
      "name": "Inquiry Stats",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/inquiries/stats?gymId={{gymId}}"
      }
    },
    {
      "name": "Add Product",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"gymId\": \"{{gymId}}\",\n  \"name\": \"Whey Protein\",\n  \"category\": \"supplements\",\n  \"stock_quantity\": 50,\n  \"cost_price\": 1000,\n  \"selling_price\": 1500,\n  \"description\": \"Premium whey\",\n  \"image_url\": \"https://cdn.example.com/whey.jpg\"\n}"
        },
        "url": "{{baseUrl}}/products"
      }
    },
    {
      "name": "List Products",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/products?gymId={{gymId}}&search=whey"
      }
    },
    {
      "name": "Get Product Details",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/products/{{productId}}?gymId={{gymId}}"
      }
    },
    {
      "name": "Update Product",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"selling_price\": 1600,\n  \"discount_price\": 1400,\n  \"description\": \"Updated description\"\n}"
        },
        "url": "{{baseUrl}}/products/{{productId}}?gymId={{gymId}}"
      }
    },
    {
      "name": "Update Stock",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"quantity\": 10,\n  \"type\": \"add\"\n}"
        },
        "url": "{{baseUrl}}/products/{{productId}}/stock?gymId={{gymId}}"
      }
    },
    {
      "name": "Delete Product",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/products/{{productId}}?gymId={{gymId}}"
      }
    },
    {
      "name": "Product Categories",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/product-categories?gymId={{gymId}}"
      }
    }
  ]
}
