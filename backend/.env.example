# Application
NODE_ENV=development
PORT=3000

# Trainer leave balance: approved days in the current UTC year are subtracted from this allowance (GET /api/v1/leaves/balance).
# TRAINER_ANNUAL_LEAVE_DAYS=12

# Database — PostgreSQL required (install locally or use a hosted instance). SQLite is not supported.
#
# Local development (copy to `.env`):
# DATABASE_URL="postgresql://developer:developer@localhost:5432/gym_tracker"
#
# Remote / hosted server (copy to `.env` when targeting the deployed DB):
# DATABASE_URL="postgres://postgres:PASSWORD@YOUR_SERVER_IP:5945/postgres"
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/gymtrak?schema=public"

# Migrations: on each server start, `prisma migrate deploy` runs automatically (applies pending migrations).
# Set to true only if your deploy pipeline already runs migrations (e.g. CI job before the app starts).
# SKIP_MIGRATIONS_ON_STARTUP=false
#
# If deploy fails with P3009 (failed migration), fix DB then from your laptop/CI with same DATABASE_URL:
#   npx prisma migrate resolve --applied MIGRATION_FOLDER_NAME
#   or: npx prisma migrate resolve --rolled-back MIGRATION_FOLDER_NAME
# See: https://pris.ly/d/migrate-resolve

# Optional: create/update a super admin for POST /api/v1/auth/staff/login (username + password).
# There is NO default password in the app — either set this once on the server, or create users via the DB / trainer flows.
# SUPER_ADMIN_BOOTSTRAP=1
# SUPER_ADMIN_BOOTSTRAP_PHONE=+10000000000
# SUPER_ADMIN_BOOTSTRAP_USERNAME=admin
# SUPER_ADMIN_BOOTSTRAP_PASSWORD=change-me-min-8-chars

# JWT (use the same value for JWT_ACCESS_SECRET in Flutter’s gym-config server / Express)
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Short-lived Bearer for POST /auth/verify-otp when phone is not registered yet (signup only routes).
JWT_TEMP_SIGNUP_EXPIRES_IN=12m

# API auth: in NODE_ENV=development, Bearer is optional; the first ACTIVE user in the DB is used as request user.
# Set DISABLE_JWT_AUTH=false to require JWT in development. Set DISABLE_JWT_AUTH=true in non-dev to allow the same bypass (not recommended for public APIs).
# AUTH_DEV_USER_ID=cuid_here
# DISABLE_JWT_AUTH=false
# Owner signup POSTs (/user/select-role, /gym, /gyms) never require Bearer; user is AUTH_DEV_USER_ID or first ACTIVE user.
# Legacy no-op (was used before signup bypass was always on): ALLOW_UNAUTHENTICATED_GYM_SETUP

# OTP — IS_MSG91_ENABLED=true sends SMS via MSG91; false uses static OTP_STATIC_CODE (no SMS)
IS_MSG91_ENABLED=false
OTP_PROVIDER=local
OTP_CODE_TTL_SECONDS=300
OTP_RESEND_COOLDOWN_SECONDS=45
OTP_MAX_ATTEMPTS=5
OTP_DEV_LOG_CODE=true
# Fixed OTP when IS_MSG91_ENABLED=false (local / dev)
OTP_STATIC_CODE=123456
# Legacy (only when OTP_PROVIDER=local): OTP_MODE=static|dynamic, OTP_STATIC_ENABLED=true

# MSG91 OTP (https://control.msg91.com) — India requires DLT-approved template
MSG91_AUTH_KEY=
# From MSG91 dashboard → OTP → Templates (copy Template / Flow ID)
MSG91_TEMPLATE_ID=
# Optional: DLT content template id from DLT portal (mapped in MSG91)
# MSG91_DLT_TEMPLATE_ID=
# Optional: sender / header id when your template requires it
# MSG91_SENDER_ID=
# OTP validity in minutes (default MSG91 account setting)
# MSG91_OTP_EXPIRY_MINUTES=10
# OTP digit count sent by MSG91 (4–9, default 6)
MSG91_OTP_LENGTH=6
MSG91_WIDGET_ID=
# Set true only after enabling "Mobile Integration" on the widget in MSG91 dashboard
MSG91_USE_WIDGET=false
# Widget auth token from MSG91 OTP → Tokens (required when MSG91_USE_WIDGET=true; NOT the auth key)
MSG91_TOKEN_AUTH=
# Refuse OTP send when MSG91_TEMPLATE_ID is missing (recommended for production)
# MSG91_REQUIRE_TEMPLATE_ID=true
# MSG91_SKIP_SEND=true
# Debug: GET /api/v1/auth/msg91/status  POST /api/v1/auth/msg91/test-send
SUBSCRIPTION_MAX_FREEZE_DAYS=60

# Redis (BullMQ — WhatsApp queue). Omit or set DISABLE_BULLMQ to run without Redis.
REDIS_URL=redis://localhost:6379
# Set to true for local dev when Redis is not running (WhatsApp jobs are no-ops).
DISABLE_BULLMQ=true

# Public links for gym QR (deep link / web)
APP_PUBLIC_URL=http://localhost:3000

# Optional extra Swagger server entry in development (omit to use http://localhost:PORT)
# SWAGGER_LOCAL_SERVER_URL=http://localhost:3000

# WhatsApp outbound: meta (default) or twilio
# WHATSAPP_PROVIDER=meta
WHATSAPP_SKIP_SEND=true

# Meta WhatsApp Cloud API
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ONBOARDING_HEADER_IMAGE_URL=https://example.com/onboarding-header.jpg
# WHATSAPP_TEMPLATE_ONBOARDING_NAME=onboarding
# WHATSAPP_TEMPLATE_PAYMENT_NAME=payment_confirmation_gt

# Twilio WhatsApp (when WHATSAPP_PROVIDER=twilio)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# AWS S3 (later)
# AWS_REGION=
# AWS_S3_BUCKET=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Mobile app config API (/api/v1/app/config)
APP_NAME=GymTrak
APP_VERSION=1.0.0
APP_FORCE_UPDATE=false
APP_MAINTENANCE_MODE=false
APP_SUPPORT_CONTACT=+919999999999
APP_DEFAULT_COUNTRY_CODE=+91
APP_FEATURE_FLAGS={"owner_auth_v2":true}
APP_LOGIN_METHODS_ENABLED={"phone":true,"email":false,"google":false,"apple":false}
APP_SPLASH_ASSETS={"logo_url":"","background_url":""}

# Firebase Cloud Messaging (optional — push mirroring when FCM is configured).
# Resolve order (Coolify / EasyPanel / Docker): PATH → JSON → discrete FIREBASE_* vars.
#
# RECOMMENDED for VPS (Coolify / EasyPanel): Option B — paste minified service account JSON:
#   node -e "console.log(JSON.stringify(require('./your-firebase-adminsdk.json')))"
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...",...}
#
# Option A — local JSON file (copy secrets/firebase-adminsdk.json.example → secrets/firebase-adminsdk.json):
# FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-adminsdk.json
#
# Option C — discrete env vars (fragile in panel UIs; PEM must be ONE line with literal \n):
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Do NOT paste multiline PEM into Coolify/EasyPanel — panels often break it (spaces / truncation).
