{
  "openapi": "3.0.3",
  "info": {
    "title": "GymTrak — Member detail profile (fragment)",
    "version": "1.0.0",
    "description": "Standalone OpenAPI document for member profile and **attendance** routes. Canonical full API: docs/gymtrak-api.openapi.json (Members tag)."
  },
  "servers": [
    {
      "url": "https://api.gym.anantalabs.in/api/v1",
      "description": "Production API"
    },
    {
      "url": "http://localhost:3000/api/v1",
      "description": "Local Nest (default PORT=3000)"
    }
  ],
  "tags": [
    {
      "name": "Members",
      "description": "Member list, detail profile, attendance summary/history, create"
    }
  ],
  "paths": {
    "/members/{memberId}": {
      "get": {
        "tags": [
          "Members"
        ],
        "summary": "Member detail profile",
        "description": "Single-call staff view: `summary` matches list card fields; `subscription` has `stats` and `current_subscription`; plus membership fields, `user` (incl. `avatarUrl`), `contact`, `tabs` (incl. `attendance` + `attendance_history` URLs), embedded **`attendance`**. Bearer required; gym owner allowed; trainer/staff need `members:manage`.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "memberId",
            "in": "path",
            "required": true,
            "description": "GymUser id (same as list `members[].id` or `items[].gymUserId`)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "gymId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Member detail",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MemberDetailResponse"
                }
              }
            }
          },
          "403": {
            "description": "Insufficient permissions"
          },
          "404": {
            "description": "Member not found"
          }
        }
      }
    },
    "/members/{memberId}/profile": {
      "get": {
        "tags": [
          "Members"
        ],
        "summary": "Member profile (legacy flat card)",
        "description": "Flat payload with `stats` and `current_subscription` only. Same auth as `GET /members/{memberId}`; prefer that route for full detail + summary + subscription together.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "memberId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "gymId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Profile card",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MemberProfileCardResponse"
                }
              }
            }
          },
          "403": {
            "description": "Insufficient permissions"
          },
          "404": {
            "description": "Member not found"
          }
        }
      }
    },
    "/members/{memberId}/attendance/summary": {
      "get": {
        "tags": ["Members"],
        "summary": "Member attendance — month summary",
        "description": "See full spec `MemberAttendanceSummaryResponse` in components. Month grid (UTC), stats, `recent_logs`, `months_overview`.",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "memberId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          { "name": "gymId", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "month", "in": "query", "required": false, "schema": { "type": "string" } },
          { "name": "year", "in": "query", "required": false, "schema": { "type": "string" } },
          {
            "name": "monthsOverviewLimit",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "minimum": 1, "maximum": 60, "default": 24 }
          },
          {
            "name": "recentLimit",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "minimum": 1, "maximum": 50, "default": 20 }
          }
        ],
        "responses": {
          "200": {
            "description": "Attendance summary",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MemberAttendanceSummaryResponse" }
              }
            }
          },
          "400": { "description": "Invalid month/year" },
          "403": { "description": "Insufficient permissions" },
          "404": { "description": "Member not found" }
        }
      }
    },
    "/members/{memberId}/attendance/history": {
      "get": {
        "tags": ["Members"],
        "summary": "Member attendance — paginated history",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "memberId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "gymId", "in": "query", "required": true, "schema": { "type": "string" } },
          {
            "name": "from",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
          },
          {
            "name": "to",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "minimum": 1, "maximum": 100, "default": 20 }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "minimum": 0, "default": 0 }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated history",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MemberAttendanceHistoryResponse" }
              }
            }
          },
          "400": { "description": "from after to" },
          "403": { "description": "Insufficient permissions" },
          "404": { "description": "Member not found" }
        }
      }
    },
    "/members/{memberId}/attendance": {
      "get": {
        "tags": ["Members"],
        "summary": "Member attendance (legacy)",
        "deprecated": true,
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "memberId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "gymId", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "month", "in": "query", "required": false, "schema": { "type": "string" } },
          { "name": "year", "in": "query", "required": false, "schema": { "type": "string" } },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "minimum": 1, "maximum": 100, "default": 20 }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "minimum": 0, "default": 0 }
          }
        ],
        "responses": {
          "200": { "description": "Summary or history shape per query" },
          "403": { "description": "Insufficient permissions" },
          "404": { "description": "Member not found" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Access token or short-lived temp signup token (temp only for POST /user/select-role, POST /gym, POST /gyms). **Normal access tokens** embed **`gymId`** (string | null): default gym for `GET|PUT|POST /profile`. Decode JWT to read claims; see **`JwtAccessTokenPayload`** schema. Legacy tokens without `gymId` may still work: validation resolves default gym from the database."
      }
    },
    "schemas": {
      "MemberListSummary": {
        "type": "object",
        "description": "Same shape as each element of `GET /members` → `members[]`",
        "properties": {
          "id": {
            "type": "string",
            "description": "GymUser id"
          },
          "name": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "description": "Lifecycle e.g. active | expired | inactive"
          },
          "plan_name": {
            "type": "string"
          },
          "expiry_date": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "profile_image": {
            "type": "string",
            "description": "Avatar URL or empty"
          }
        }
      },
      "MemberSubscriptionStats": {
        "type": "object",
        "properties": {
          "active_subscription": {
            "type": "integer"
          },
          "pending_payment": {
            "type": "integer"
          },
          "overdue": {
            "type": "integer"
          }
        }
      },
      "MemberCurrentSubscription": {
        "type": "object",
        "nullable": true,
        "properties": {
          "plan_name": {
            "type": "string"
          },
          "start_date": {
            "type": "string",
            "format": "date-time"
          },
          "expiry_date": {
            "type": "string",
            "format": "date-time"
          },
          "remaining_days": {
            "type": "integer"
          },
          "amount_paid": {
            "type": "integer"
          },
          "amount_pending": {
            "type": "integer"
          }
        }
      },
      "AttendancePunctuality": {
        "type": "string",
        "enum": ["EARLY", "ON_TIME", "REGULAR", "LATE"]
      },
      "MemberAttendanceLogEntry": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "headline": { "type": "string" },
          "punctuality": { "$ref": "#/components/schemas/AttendancePunctuality" },
          "punctuality_label": { "type": "string" },
          "attended_on": { "type": "string" },
          "checked_in_at": { "type": "string", "format": "date-time" },
          "checked_out_at": { "type": "string", "format": "date-time", "nullable": true },
          "display_relative": { "type": "string" }
        }
      },
      "MemberAttendanceMonthOverview": {
        "type": "object",
        "properties": {
          "year": { "type": "integer" },
          "month": { "type": "integer" },
          "month_label": { "type": "string" },
          "days_present": { "type": "integer" },
          "total_check_ins": { "type": "integer" },
          "days_in_month": { "type": "integer" }
        }
      },
      "MemberAttendanceSummaryResponse": {
        "type": "object",
        "properties": {
          "filter": {
            "type": "object",
            "properties": {
              "year": { "type": "integer" },
              "month": { "type": "integer" },
              "month_label": { "type": "string" }
            }
          },
          "gym_timezone": { "type": "string" },
          "stats": {
            "type": "object",
            "properties": {
              "days_present_month": { "type": "integer" },
              "days_in_month": { "type": "integer" },
              "lifetime_check_ins": { "type": "integer" },
              "present_days": { "type": "integer" },
              "total_days": { "type": "integer" }
            }
          },
          "calendar": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "date": { "type": "string" },
                "status": { "type": "string", "enum": ["present", "absent"] }
              }
            }
          },
          "recent_logs": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/MemberAttendanceLogEntry" }
          },
          "months_overview": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/MemberAttendanceMonthOverview" }
          }
        }
      },
      "MemberAttendanceHistoryResponse": {
        "type": "object",
        "properties": {
          "filters": {
            "type": "object",
            "properties": {
              "from": { "type": "string", "nullable": true },
              "to": { "type": "string", "nullable": true }
            }
          },
          "gym_timezone": { "type": "string" },
          "total": { "type": "integer" },
          "limit": { "type": "integer" },
          "offset": { "type": "integer" },
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/MemberAttendanceLogEntry" }
          }
        }
      },
      "MemberDetailAttendanceLinks": {
        "type": "object",
        "properties": {
          "summary": { "type": "string" },
          "history": { "type": "string" }
        }
      },
      "MemberDetailAttendance": {
        "type": "object",
        "properties": {
          "lifetime_check_ins": { "type": "integer" },
          "last_check_in_at": { "type": "string", "format": "date-time", "nullable": true },
          "last_attended_on": { "type": "string", "nullable": true },
          "links": { "$ref": "#/components/schemas/MemberDetailAttendanceLinks" }
        }
      },
      "MemberDetailResponse": {
        "type": "object",
        "properties": {
          "gymUserId": {
            "type": "string"
          },
          "gymId": {
            "type": "string"
          },
          "lifecycleStatus": {
            "type": "string"
          },
          "isLead": {
            "type": "boolean"
          },
          "isActive": {
            "type": "boolean"
          },
          "membershipEndsAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "joinedAt": {
            "type": "string",
            "format": "date-time"
          },
          "notes": {
            "type": "string",
            "nullable": true
          },
          "emergencyContactName": {
            "type": "string",
            "nullable": true
          },
          "emergencyContactPhone": {
            "type": "string",
            "nullable": true
          },
          "dateOfBirth": {
            "type": "string",
            "format": "date",
            "nullable": true
          },
          "gender": {
            "type": "string",
            "nullable": true
          },
          "summary": {
            "$ref": "#/components/schemas/MemberListSummary"
          },
          "subscription": {
            "type": "object",
            "properties": {
              "stats": {
                "$ref": "#/components/schemas/MemberSubscriptionStats"
              },
              "current_subscription": {
                "$ref": "#/components/schemas/MemberCurrentSubscription"
              }
            }
          },
          "user": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "fullName": {
                "type": "string",
                "nullable": true
              },
              "phone": {
                "type": "string"
              },
              "email": {
                "type": "string",
                "nullable": true
              },
              "heightCm": {
                "type": "number",
                "nullable": true
              },
              "weightKg": {
                "type": "number",
                "nullable": true
              },
              "createdAt": {
                "type": "string",
                "format": "date-time"
              },
              "avatarUrl": {
                "type": "string",
                "nullable": true
              }
            }
          },
          "contact": {
            "type": "object",
            "properties": {
              "phone": {
                "type": "string"
              },
              "telUri": {
                "type": "string",
                "nullable": true
              },
              "whatsappUrl": {
                "type": "string",
                "nullable": true
              }
            }
          },
          "tabs": {
            "type": "object",
            "properties": {
              "subscriptions": {
                "type": "string"
              },
              "attendance": {
                "type": "string"
              },
              "attendance_history": {
                "type": "string"
              },
              "payments": {
                "type": "string"
              }
            }
          },
          "attendance": {
            "$ref": "#/components/schemas/MemberDetailAttendance"
          }
        }
      },
      "MemberProfileCardResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "gender": {
            "type": "string",
            "nullable": true
          },
          "dob": {
            "type": "string",
            "format": "date",
            "nullable": true
          },
          "join_date": {
            "type": "string",
            "format": "date-time"
          },
          "status": {
            "type": "string"
          },
          "profile_image": {
            "type": "string"
          },
          "stats": {
            "$ref": "#/components/schemas/MemberSubscriptionStats"
          },
          "current_subscription": {
            "$ref": "#/components/schemas/MemberCurrentSubscription"
          }
        }
      }
    }
  }
}